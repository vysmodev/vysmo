{
  "name": "@vysmo/animations",
  "version": "0.4.0",
  "description": "Value-based tweening primitives — animate(), spring(), timeline(), interpolate(). DOM-agnostic core that drives anything a number can change: CSS transforms, WebGL uniforms, canvas draws, audio params.",
  "license": "MIT",
  "keywords": [
    "animation",
    "animate",
    "tween",
    "spring",
    "timeline",
    "interpolation",
    "easing",
    "headless",
    "tree-shakable"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --format=cjs --platform=neutral --outfile=dist/index.cjs --external:@vysmo/* --external:react --external:react-dom --external:react/jsx-runtime",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:main": "vitest run",
    "test:ssr": "vitest run --config vitest.ssr.config.ts",
    "test:watch": "vitest",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@vysmo/easings": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}

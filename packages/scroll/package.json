{
  "name": "@vysmo/scroll",
  "version": "0.2.0",
  "description": "Scroll-driven primitives that compose with the ecosystem: bind scroll progress to any @vysmo/transitions or @vysmo/effects render. Shared rAF-throttled observer, headless.",
  "license": "MIT",
  "keywords": [
    "scroll",
    "scroll-driven",
    "progress",
    "scroll-transition",
    "scroll-effect",
    "webgl",
    "headless"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:browser": "vitest run",
    "test:ssr": "vitest run --config vitest.ssr.config.ts",
    "test:watch": "vitest",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@vysmo/effects": "workspace:*",
    "@vysmo/transitions": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser": "^3.2.4",
    "esbuild": "^0.28.0",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}

{
  "name": "@vysmo/text",
  "version": "0.2.0",
  "description": "Multi-property choreographed text animation with a 300+ preset catalog. Grapheme-safe splitting via Intl.Segmenter; per-slice stagger / jitter / range; serializable preset format (string easings, normalized origins) so the same data drives DOM today and canvas tomorrow.",
  "license": "MIT",
  "keywords": [
    "text",
    "animation",
    "split",
    "stagger",
    "kinetic-typography",
    "choreography",
    "presets",
    "intl-segmenter",
    "tree-shakable",
    "headless"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:browser": "vitest run",
    "test:ssr": "vitest run --config vitest.ssr.config.ts",
    "test:watch": "vitest",
    "ingest": "node scripts/ingest-generated.mjs",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@vysmo/animations": "workspace:*",
    "@vysmo/easings": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser": "^3.2.4",
    "esbuild": "^0.28.0",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
